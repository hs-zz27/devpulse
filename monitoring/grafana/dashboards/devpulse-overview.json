{
    "uid": "devpulse-overview",
    "title": "DevPulse Overview",
    "tags": [
        "devpulse",
        "prometheus"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "10s",
    "panels": [
        {
            "type": "stat",
            "title": "Webhook Rate",
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 6,
                "h": 4
            },
            "targets": [
                {
                    "expr": "sum(rate(devpulse_webhooks_total[5m]))",
                    "legendFormat": "webhooks/sec"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Webhooks by Event",
            "gridPos": {
                "x": 6,
                "y": 0,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "sum by (event, action) (rate(devpulse_webhooks_total[5m]))",
                    "legendFormat": "{event} / {action}"
                }
            ]
        },
        {
            "type": "stat",
            "title": "Current Queue Depth",
            "gridPos": {
                "x": 18,
                "y": 0,
                "w": 6,
                "h": 4
            },
            "targets": [
                {
                    "expr": "devpulse_queue_depth",
                    "legendFormat": "queue depth"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Queue Depth Over Time",
            "gridPos": {
                "x": 0,
                "y": 8,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "devpulse_queue_depth",
                    "legendFormat": "queue depth"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Review Completion Rate by Status",
            "gridPos": {
                "x": 12,
                "y": 8,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "sum by (status) (rate(devpulse_reviews_completed_total[5m]))",
                    "legendFormat": "{status}"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "p95 Review Duration",
            "gridPos": {
                "x": 0,
                "y": 16,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum by (le, status) (rate(devpulse_review_duration_seconds_bucket[5m])))",
                    "legendFormat": "95th Percentile for {status}"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Average Review Duration",
            "gridPos": {
                "x": 12,
                "y": 16,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "sum by (status) (rate(devpulse_review_duration_seconds_sum[5m])) / sum by (status) (rate(devpulse_review_duration_seconds_count[5m]))",
                    "legendFormat": "avg {status}"
                }
            ]
        }
    ]
}