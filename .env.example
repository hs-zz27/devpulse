# ──────────────────────────────────────────────
# DevPulse — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DB_PASSWORD=devpulse_local_password
DATABASE_URL=postgresql+asyncpg://devpulse:devpulse_local_password@localhost:5432/devpulse

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_ME_WITH_RANDOM_64_CHAR_HEX

# ── GitHub OAuth App ──────────────────────────
# Create at: https://github.com/settings/developers → "New OAuth App"
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=REPLACE_ME
GITHUB_CLIENT_SECRET=REPLACE_ME

# ── Google Gemini ─────────────────────────────
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE_ME

# ── App Settings ──────────────────────────────
# Used to generate webhook URLs that GitHub sends events to
# In local dev, you'll use ngrok to get a public URL (Step 2.3 in guide)
BASE_URL=http://localhost:8000

# Environment: development | production
ENVIRONMENT=development
